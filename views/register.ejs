<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body class="min-h-screen flex items-center justify-center py-10">
  <div class="card w-full max-w-md rounded-2xl p-8">
    <div class="text-center mb-6">
      <div class="w-14 h-14 rounded-xl bg-accent mx-auto flex items-center justify-center text-white text-2xl font-bold">P</div>
      <h1 class="text-white text-2xl font-bold mt-3">Create Account</h1>
      <p class="text-gray-400 text-sm mt-1">Join <%= settings.panel_name || 'Pterodactyl Dashboard' %></p>
    </div>
    <% if (error && error.length) { %>
      <div class="bg-red-500/10 border border-red-500/30 text-red-400 text-sm rounded-lg p-3 mb-4"><%= error[0] %></div>
    <% } %>
    <form method="POST" action="/register" class="space-y-4">
      <div>
        <label class="text-gray-300 text-sm">Username</label>
        <input type="text" name="username" required class="w-full mt-1 bg-white/5 border border-white/10 rounded-lg px-4 py-2.5 text-white outline-none focus:border-accent">
      </div>
      <div>
        <label class="text-gray-300 text-sm">Email</label>
        <input type="email" name="email" required class="w-full mt-1 bg-white/5 border border-white/10 rounded-lg px-4 py-2.5 text-white outline-none focus:border-accent">
      </div>
      <div>
        <label class="text-gray-300 text-sm">Discord ID <span class="text-red-400">*required*</span></label>
        <input type="text" name="discord_id" required placeholder="e.g. 123456789012345678" class="w-full mt-1 bg-white/5 border border-white/10 rounded-lg px-4 py-2.5 text-white outline-none focus:border-accent">
      </div>
      <div>
        <label class="text-gray-300 text-sm">Password</label>
        <input type="password" name="password" required class="w-full mt-1 bg-white/5 border border-white/10 rounded-lg px-4 py-2.5 text-white outline-none focus:border-accent">
      </div>
      <div>
        <label class="text-gray-300 text-sm">Confirm Password</label>
        <input type="password" name="confirm_password" required class="w-full mt-1 bg-white/5 border border-white/10 rounded-lg px-4 py-2.5 text-white outline-none focus:border-accent">
      </div>
      <button type="submit" class="w-full btn-accent text-white font-semibold rounded-lg py-2.5">Register</button>
    </form>
    <p class="text-gray-400 text-sm text-center mt-5">Already have an account? <a href="/login" class="accent font-medium">Login</a></p>
  </div>
</body>
</html>
