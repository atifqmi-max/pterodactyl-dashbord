<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen">
  <%- include('../partials/nav') %>
  <div class="max-w-6xl mx-auto px-6 py-8">
    <div class="flex items-center justify-between mb-4">
      <h1 class="text-white text-2xl font-bold">Plans</h1>
      <button onclick="document.getElementById('newPlanModal').classList.remove('hidden')" class="btn-accent text-white text-sm font-medium px-4 py-2 rounded-lg">+ Add New Plan</button>
    </div>
    <% if (success && success.length) { %><div class="bg-green-500/10 border border-green-500/30 text-green-400 text-sm rounded-lg p-3 mb-4"><%= success[0] %></div><% } %>
    <% if (error && error.length) { %><div class="bg-red-500/10 border border-red-500/30 text-red-400 text-sm rounded-lg p-3 mb-4"><%= error[0] %></div><% } %>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <% plans.forEach(p => { %>
        <div class="card rounded-2xl p-6">
          <h3 class="text-white text-xl font-bold"><%= p.name %></h3>
          <p class="text-2xl font-extrabold accent mt-1">🪙 <%= p.price %></p>
          <ul class="text-gray-300 text-sm mt-3 space-y-1">
            <li>💾 RAM: <%= p.ram %> MB</li>
            <li>⚙️ CPU: <%= p.cpu %>%</li>
            <li>📀 Disk: <%= p.disk %> MB</li>
            <li>🔌 Allocations: <%= p.allocations %></li>
            <li>♻️ Backups: <%= p.backups %></li>
            <li>⏳ Duration: <%= p.duration_days %> days</li>
          </ul>
          <form method="POST" action="/admin/plans/<%= p.id %>/delete" class="mt-4" onsubmit="return confirm('Delete this plan?')">
            <button class="w-full bg-red-500/20 hover:bg-red-500/30 text-red-400 rounded-lg py-2 text-sm">Delete Plan</button>
          </form>
        </div>
      <% }) %>
      <% if (!plans.length) { %><p class="text-gray-500 col-span-3 text-center py-10">No plans yet. Add one!</p><% } %>
    </div>
  </div>

  <div id="newPlanModal" class="hidden fixed inset-0 bg-black/70 flex items-center justify-center px-4 overflow-y-auto py-10">
    <div class="card rounded-2xl p-6 w-full max-w-md">
      <h3 class="text-white font-bold text-lg mb-4">Add New Plan</h3>
      <form method="POST" action="/admin/plans/new" class="space-y-3">
        <input name="name" placeholder="Plan Name" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm">
        <input name="price" type="number" placeholder="Price (coins)" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm">
        <input name="ram" type="number" placeholder="RAM (MB)" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm">
        <input name="cpu" type="number" placeholder="CPU (%)" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm">
        <input name="disk" type="number" placeholder="Disk (MB)" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm">
        <input name="allocations" type="number" placeholder="Allocation (Ports)" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm">
        <input name="backups" type="number" placeholder="Backup Limit" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm">
        <input name="duration_days" type="number" placeholder="Duration (days)" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm">
        <div class="flex gap-2 pt-2">
          <button type="button" onclick="document.getElementById('newPlanModal').classList.add('hidden')" class="flex-1 bg-white/10 text-white rounded-lg py-2 text-sm">Cancel</button>
          <button type="submit" class="flex-1 btn-accent text-white rounded-lg py-2 text-sm font-medium">Add Plan</button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
