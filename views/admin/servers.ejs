<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen">
  <%- include('../partials/nav') %>
  <div class="max-w-6xl mx-auto px-6 py-8">
    <h1 class="text-white text-2xl font-bold mb-4">All Purchased Servers</h1>
    <% if (success && success.length) { %><div class="bg-green-500/10 border border-green-500/30 text-green-400 text-sm rounded-lg p-3 mb-4"><%= success[0] %></div><% } %>
    <% if (error && error.length) { %><div class="bg-red-500/10 border border-red-500/30 text-red-400 text-sm rounded-lg p-3 mb-4"><%= error[0] %></div><% } %>

    <div class="card rounded-xl overflow-hidden">
      <table class="w-full text-sm text-left">
        <thead class="bg-white/5 text-gray-400">
          <tr><th class="px-4 py-3">Server</th><th class="px-4 py-3">Owner</th><th class="px-4 py-3">Plan</th><th class="px-4 py-3">Expires</th><th class="px-4 py-3">Status</th><th class="px-4 py-3">Actions</th></tr>
        </thead>
        <tbody class="text-gray-200 divide-y divide-white/5">
          <% servers.forEach(s => { %>
            <tr>
              <td class="px-4 py-3 font-medium"><%= s.name %></td>
              <td class="px-4 py-3"><%= s.username %> (<%= s.email %>)</td>
              <td class="px-4 py-3"><%= s.plan_name %></td>
              <td class="px-4 py-3"><%= new Date(s.expires_at).toLocaleDateString() %></td>
              <td class="px-4 py-3"><span class="px-2 py-1 rounded-full text-xs <%= s.status === 'active' ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400' %>"><%= s.status %></span></td>
              <td class="px-4 py-3 space-x-1 whitespace-nowrap">
                <form method="POST" action="/admin/servers/<%= s.id %>/move-owner" class="inline-flex gap-1">
                  <input type="number" name="new_user_id" placeholder="User ID" class="w-16 bg-white/5 border border-white/10 rounded px-1 py-1 text-xs text-white">
                  <button class="bg-white/10 hover:bg-white/20 text-white text-xs px-2 py-1 rounded">Move Owner</button>
                </form>
                <form method="POST" action="/admin/servers/<%= s.id %>/move-node" class="inline-flex gap-1">
                  <select name="location_id" class="bg-white/5 border border-white/10 rounded px-1 py-1 text-xs text-white">
                    <% locations.forEach(l => { %><option value="<%= l.attributes.id %>"><%= l.attributes.short %></option><% }) %>
                  </select>
                  <button class="bg-white/10 hover:bg-white/20 text-white text-xs px-2 py-1 rounded">Move Node</button>
                </form>
                <form method="POST" action="/admin/servers/<%= s.id %>/delete" class="inline" onsubmit="return confirm('Delete this server from panel and database?')">
                  <button class="bg-red-500/20 hover:bg-red-500/30 text-red-400 text-xs px-2 py-1 rounded">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
          <% if (!servers.length) { %><tr><td colspan="6" class="px-4 py-6 text-center text-gray-500">No servers purchased yet.</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
