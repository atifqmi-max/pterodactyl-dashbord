<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen">
  <%- include('../partials/nav') %>
  <div class="max-w-2xl mx-auto px-6 py-8">
    <h1 class="text-white text-2xl font-bold mb-4">Settings</h1>
    <% if (success && success.length) { %><div class="bg-green-500/10 border border-green-500/30 text-green-400 text-sm rounded-lg p-3 mb-4"><%= success[0] %></div><% } %>
    <% if (error && error.length) { %><div class="bg-red-500/10 border border-red-500/30 text-red-400 text-sm rounded-lg p-3 mb-4"><%= error[0] %></div><% } %>

    <form method="POST" action="/admin/settings" class="card rounded-2xl p-6 space-y-4">
      <h3 class="text-white font-semibold">Pterodactyl Connection</h3>
      <div>
        <label class="text-gray-300 text-sm">Panel URL</label>
        <input name="panel_url" value="<%= settings.panel_url %>" placeholder="https://panel.yourdomain.com" class="w-full mt-1 bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm">
      </div>
      <div>
        <label class="text-gray-300 text-sm">Panel API Key (Application API)</label>
        <input name="panel_api_key" value="<%= settings.panel_api_key %>" type="password" class="w-full mt-1 bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm">
      </div>
      <div class="grid grid-cols-3 gap-3">
        <div><label class="text-gray-300 text-xs">Default Nest ID</label><input name="default_nest_id" value="<%= settings.default_nest_id %>" class="w-full mt-1 bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm"></div>
        <div><label class="text-gray-300 text-xs">Default Egg ID</label><input name="default_egg_id" value="<%= settings.default_egg_id %>" class="w-full mt-1 bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm"></div>
        <div><label class="text-gray-300 text-xs">Default Location ID</label><input name="default_location_id" value="<%= settings.default_location_id %>" class="w-full mt-1 bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm"></div>
      </div>

      <hr class="border-white/10 my-2">
      <h3 class="text-white font-semibold">Theme & Branding</h3>
      <div>
        <label class="text-gray-300 text-sm">Panel Name</label>
        <input name="panel_name" value="<%= settings.panel_name %>" class="w-full mt-1 bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm">
      </div>
      <div>
        <label class="text-gray-300 text-sm">Accent/Theme Color</label>
        <input name="theme_color" type="color" value="<%= settings.theme_color %>" class="w-full mt-1 h-10 bg-white/5 border border-white/10 rounded-lg">
      </div>
      <div>
        <label class="text-gray-300 text-sm">Background Image URL</label>
        <input name="background_url" value="<%= settings.background_url || '' %>" placeholder="https://.../background.jpg" class="w-full mt-1 bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm">
      </div>

      <button type="submit" class="w-full btn-accent text-white font-semibold rounded-lg py-2.5 mt-2">Save Settings</button>
    </form>
  </div>
</body>
</html>
