<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen">
  <%- include('../partials/nav') %>
  <div class="max-w-6xl mx-auto px-6 py-8">
    <div class="flex items-center justify-between mb-4">
      <h1 class="text-white text-2xl font-bold">Redeem Codes</h1>
      <button onclick="document.getElementById('newCodeModal').classList.remove('hidden')" class="btn-accent text-white text-sm font-medium px-4 py-2 rounded-lg">+ New Redeem Code</button>
    </div>
    <% if (success && success.length) { %><div class="bg-green-500/10 border border-green-500/30 text-green-400 text-sm rounded-lg p-3 mb-4"><%= success[0] %></div><% } %>
    <% if (error && error.length) { %><div class="bg-red-500/10 border border-red-500/30 text-red-400 text-sm rounded-lg p-3 mb-4"><%= error[0] %></div><% } %>

    <div class="card rounded-xl overflow-hidden">
      <table class="w-full text-sm text-left">
        <thead class="bg-white/5 text-gray-400">
          <tr><th class="px-4 py-3">Code</th><th class="px-4 py-3">Coins</th><th class="px-4 py-3">Claims</th><th class="px-4 py-3">Action</th></tr>
        </thead>
        <tbody class="text-gray-200 divide-y divide-white/5">
          <% codes.forEach(c => { %>
            <tr>
              <td class="px-4 py-3 font-mono font-semibold"><%= c.code %></td>
              <td class="px-4 py-3 text-yellow-400">🪙 <%= c.coins %></td>
              <td class="px-4 py-3"><%= c.claims_used %> / <%= c.max_claims %></td>
              <td class="px-4 py-3">
                <form method="POST" action="/admin/redeem-codes/<%= c.id %>/delete" onsubmit="return confirm('Delete this code?')">
                  <button class="bg-red-500/20 hover:bg-red-500/30 text-red-400 text-xs px-2 py-1 rounded">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
          <% if (!codes.length) { %><tr><td colspan="4" class="px-4 py-6 text-center text-gray-500">No redeem codes yet.</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div>

  <div id="newCodeModal" class="hidden fixed inset-0 bg-black/70 flex items-center justify-center px-4">
    <div class="card rounded-2xl p-6 w-full max-w-sm">
      <h3 class="text-white font-bold text-lg mb-4">Create Redeem Code</h3>
      <form method="POST" action="/admin/redeem-codes/new" class="space-y-3">
        <input name="code" placeholder="Code (e.g. SUMMER2026)" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm uppercase">
        <input name="coins" type="number" placeholder="Coins per claim" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm">
        <input name="max_claims" type="number" placeholder="Total members who can claim" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm">
        <div class="flex gap-2 pt-2">
          <button type="button" onclick="document.getElementById('newCodeModal').classList.add('hidden')" class="flex-1 bg-white/10 text-white rounded-lg py-2 text-sm">Cancel</button>
          <button type="submit" class="flex-1 btn-accent text-white rounded-lg py-2 text-sm font-medium">Create</button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
