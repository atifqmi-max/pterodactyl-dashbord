<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen">
  <%- include('../partials/nav') %>
  <div class="max-w-6xl mx-auto px-6 py-8">
    <div class="flex items-center justify-between mb-4">
      <h1 class="text-white text-2xl font-bold">Users</h1>
      <button onclick="document.getElementById('newAdminModal').classList.remove('hidden')" class="btn-accent text-white text-sm font-medium px-4 py-2 rounded-lg">+ Create New Admin</button>
    </div>
    <% if (success && success.length) { %><div class="bg-green-500/10 border border-green-500/30 text-green-400 text-sm rounded-lg p-3 mb-4"><%= success[0] %></div><% } %>
    <% if (error && error.length) { %><div class="bg-red-500/10 border border-red-500/30 text-red-400 text-sm rounded-lg p-3 mb-4"><%= error[0] %></div><% } %>

    <div class="card rounded-xl overflow-hidden">
      <table class="w-full text-sm text-left">
        <thead class="bg-white/5 text-gray-400">
          <tr><th class="px-4 py-3">Username</th><th class="px-4 py-3">Email</th><th class="px-4 py-3">Discord ID</th><th class="px-4 py-3">Coins</th><th class="px-4 py-3">Role</th><th class="px-4 py-3">Actions</th></tr>
        </thead>
        <tbody class="text-gray-200 divide-y divide-white/5">
          <% users.forEach(u => { %>
            <tr>
              <td class="px-4 py-3 font-medium"><%= u.username %></td>
              <td class="px-4 py-3"><%= u.email %></td>
              <td class="px-4 py-3 text-gray-400"><%= u.discord_id %></td>
              <td class="px-4 py-3">
                <form method="POST" action="/admin/users/<%= u.id %>/coins" class="flex items-center gap-1">
                  <input type="number" name="coins" value="<%= u.coins %>" class="w-20 bg-white/5 border border-white/10 rounded px-2 py-1 text-white text-xs">
                  <button class="text-xs accent">Save</button>
                </form>
              </td>
              <td class="px-4 py-3"><%= u.is_admin ? 'Admin' : 'Member' %></td>
              <td class="px-4 py-3 space-x-2 whitespace-nowrap">
                <% if (u.is_admin) { %>
                  <form method="POST" action="/admin/users/<%= u.id %>/remove-admin" class="inline"><button class="bg-white/10 hover:bg-white/20 text-white text-xs px-2 py-1 rounded">Remove Admin</button></form>
                <% } else { %>
                  <form method="POST" action="/admin/users/<%= u.id %>/make-admin" class="inline"><button class="bg-white/10 hover:bg-white/20 text-white text-xs px-2 py-1 rounded">Make Admin</button></form>
                <% } %>
                <form method="POST" action="/admin/users/<%= u.id %>/delete" class="inline" onsubmit="return confirm('Delete this user permanently?')"><button class="bg-red-500/20 hover:bg-red-500/30 text-red-400 text-xs px-2 py-1 rounded">Delete</button></form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <div id="newAdminModal" class="hidden fixed inset-0 bg-black/70 flex items-center justify-center px-4">
    <div class="card rounded-2xl p-6 w-full max-w-sm">
      <h3 class="text-white font-bold text-lg mb-4">Create New Admin</h3>
      <form method="POST" action="/admin/users/new-admin" class="space-y-3">
        <input name="username" placeholder="Username" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm">
        <input name="email" type="email" placeholder="Email" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm">
        <input name="password" type="password" placeholder="Password" required class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm">
        <input name="discord_id" placeholder="Discord ID" class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-sm">
        <div class="flex gap-2 pt-2">
          <button type="button" onclick="document.getElementById('newAdminModal').classList.add('hidden')" class="flex-1 bg-white/10 text-white rounded-lg py-2 text-sm">Cancel</button>
          <button type="submit" class="flex-1 btn-accent text-white rounded-lg py-2 text-sm font-medium">Create</button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
