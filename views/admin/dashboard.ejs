<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen">
  <%- include('../partials/nav') %>
  <div class="max-w-6xl mx-auto px-6 py-8">
    <h1 class="text-white text-2xl font-bold mb-6">Admin Overview</h1>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
      <div class="card rounded-xl p-5"><p class="text-gray-400 text-sm">Total Users</p><p class="text-3xl font-bold text-white mt-1"><%= totalUsers %></p></div>
      <div class="card rounded-xl p-5"><p class="text-gray-400 text-sm">Total Servers</p><p class="text-3xl font-bold text-white mt-1"><%= totalServers %></p></div>
      <div class="card rounded-xl p-5"><p class="text-gray-400 text-sm">Total Coins in Economy</p><p class="text-3xl font-bold text-yellow-400 mt-1">🪙 <%= totalCoins %></p></div>
    </div>

    <h2 class="text-white text-lg font-semibold mb-3">⏰ Expiring Within 5 Days</h2>
    <div class="card rounded-xl overflow-hidden">
      <table class="w-full text-sm text-left">
        <thead class="bg-white/5 text-gray-400">
          <tr><th class="px-4 py-3">User</th><th class="px-4 py-3">Discord ID</th><th class="px-4 py-3">Server</th><th class="px-4 py-3">Plan</th><th class="px-4 py-3">Expires</th></tr>
        </thead>
        <tbody class="text-gray-200 divide-y divide-white/5">
          <% if (!expiringSoon.length) { %>
            <tr><td colspan="5" class="px-4 py-6 text-center text-gray-500">No servers expiring soon.</td></tr>
          <% } %>
          <% expiringSoon.forEach(s => { %>
            <tr>
              <td class="px-4 py-3"><%= s.username %> (<%= s.email %>)</td>
              <td class="px-4 py-3 text-gray-400"><%= s.discord_id %></td>
              <td class="px-4 py-3"><%= s.name %></td>
              <td class="px-4 py-3"><%= s.plan_name %></td>
              <td class="px-4 py-3 text-orange-400"><%= new Date(s.expires_at).toLocaleString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
