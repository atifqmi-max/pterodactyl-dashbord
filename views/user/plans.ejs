<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen">
  <%- include('../partials/nav') %>
  <div class="max-w-6xl mx-auto px-6 py-8">
    <h1 class="text-white text-2xl font-bold mb-1">Available Plans</h1>
    <p class="text-gray-400 mb-6">Buy a plan using your coins — server auto-deploys instantly.</p>

    <% if (success && success.length) { %>
      <div class="bg-green-500/10 border border-green-500/30 text-green-400 text-sm rounded-lg p-3 mb-4"><%= success[0] %></div>
    <% } %>
    <% if (msg && msg.length) { %>
      <div class="bg-red-500/10 border border-red-500/30 text-red-400 text-sm rounded-lg p-3 mb-4"><%= msg[0] %></div>
    <% } %>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <% plans.forEach(p => { %>
        <div class="card rounded-2xl p-6 flex flex-col">
          <h3 class="text-white text-xl font-bold"><%= p.name %></h3>
          <p class="text-3xl font-extrabold accent mt-2">🪙 <%= p.price %></p>
          <ul class="text-gray-300 text-sm mt-4 space-y-2 flex-1">
            <li>💾 RAM: <%= p.ram %> MB</li>
            <li>⚙️ CPU: <%= p.cpu %>%</li>
            <li>📀 Disk: <%= p.disk %> MB</li>
            <li>🔌 Allocations: <%= p.allocations %></li>
            <li>♻️ Backups: <%= p.backups %></li>
            <li>⏳ Duration: <%= p.duration_days %> days</li>
          </ul>
          <form method="POST" action="/plans/<%= p.id %>/buy" class="mt-5">
            <button class="w-full btn-accent text-white font-semibold rounded-lg py-2.5">Buy Now</button>
          </form>
        </div>
      <% }) %>
      <% if (!plans.length) { %>
        <p class="text-gray-500 col-span-3 text-center py-10">No plans available yet. Check back soon.</p>
      <% } %>
    </div>
  </div>
</body>
</html>
