<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen">
  <%- include('../partials/nav') %>
  <div class="max-w-6xl mx-auto px-6 py-8">
    <h1 class="text-white text-2xl font-bold mb-1">Welcome, <%= user.username %> 👋</h1>
    <p class="text-gray-400 mb-6">Manage your servers and coins from here.</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
      <div class="card rounded-xl p-5">
        <p class="text-gray-400 text-sm">Coin Balance</p>
        <p class="text-3xl font-bold text-yellow-400 mt-1">🪙 <%= user.coins %></p>
      </div>
      <div class="card rounded-xl p-5">
        <p class="text-gray-400 text-sm">Active Servers</p>
        <p class="text-3xl font-bold text-white mt-1"><%= servers.filter(s => s.status === 'active').length %></p>
      </div>
      <div class="card rounded-xl p-5 flex items-center justify-between">
        <div>
          <p class="text-gray-400 text-sm">Need more coins?</p>
          <a href="/redeem" class="accent font-semibold">Redeem a code →</a>
        </div>
      </div>
    </div>

    <div class="flex items-center justify-between mb-3">
      <h2 class="text-white text-lg font-semibold">My Servers</h2>
      <a href="/plans" class="btn-accent text-white text-sm font-medium px-4 py-2 rounded-lg">+ Buy New Server</a>
    </div>

    <div class="card rounded-xl overflow-hidden">
      <table class="w-full text-sm text-left">
        <thead class="bg-white/5 text-gray-400">
          <tr>
            <th class="px-4 py-3">Server</th>
            <th class="px-4 py-3">Plan</th>
            <th class="px-4 py-3">Resources</th>
            <th class="px-4 py-3">Expires</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Action</th>
          </tr>
        </thead>
        <tbody class="text-gray-200 divide-y divide-white/5">
          <% if (!servers.length) { %>
            <tr><td colspan="6" class="px-4 py-6 text-center text-gray-500">No servers yet. Buy a plan to get started!</td></tr>
          <% } %>
          <% servers.forEach(s => { %>
            <tr>
              <td class="px-4 py-3 font-medium"><%= s.name %></td>
              <td class="px-4 py-3"><%= s.plan_name %></td>
              <td class="px-4 py-3 text-gray-400"><%= s.ram %>MB / <%= s.cpu %>% / <%= s.disk %>MB</td>
              <td class="px-4 py-3"><%= new Date(s.expires_at).toLocaleDateString() %></td>
              <td class="px-4 py-3">
                <span class="px-2 py-1 rounded-full text-xs <%= s.status === 'active' ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400' %>">
                  <%= s.status %>
                </span>
              </td>
              <td class="px-4 py-3 space-x-2">
                <a href="<%= panelUrl %>/server/<%= s.ptero_identifier %>" target="_blank" class="btn-accent text-white text-xs font-medium px-3 py-1.5 rounded-lg inline-block">Manage Now</a>
                <form method="POST" action="/servers/<%= s.id %>/renew" class="inline">
                  <button class="bg-white/10 hover:bg-white/20 text-white text-xs font-medium px-3 py-1.5 rounded-lg">Renew</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
