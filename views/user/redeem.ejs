<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen">
  <%- include('../partials/nav') %>
  <div class="max-w-md mx-auto px-6 py-16">
    <div class="card rounded-2xl p-8 text-center">
      <div class="text-4xl mb-3">🎁</div>
      <h1 class="text-white text-2xl font-bold mb-1">Redeem a Code</h1>
      <p class="text-gray-400 text-sm mb-6">Enter your code below to receive coins instantly.</p>

      <% if (success && success.length) { %>
        <div class="bg-green-500/10 border border-green-500/30 text-green-400 text-sm rounded-lg p-3 mb-4"><%= success[0] %></div>
      <% } %>
      <% if (error && error.length) { %>
        <div class="bg-red-500/10 border border-red-500/30 text-red-400 text-sm rounded-lg p-3 mb-4"><%= error[0] %></div>
      <% } %>

      <form method="POST" action="/redeem" class="space-y-4">
        <input type="text" name="code" required placeholder="Enter redeem code" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white text-center tracking-widest uppercase outline-none focus:border-accent">
        <button type="submit" class="w-full btn-accent text-white font-semibold rounded-lg py-2.5">Redeem</button>
      </form>
    </div>
  </div>
</body>
</html>
