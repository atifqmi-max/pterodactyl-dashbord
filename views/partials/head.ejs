<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= settings.panel_name || 'Pterodactyl Dashboard' %></title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap">
<style>
  :root { --accent: <%= settings.theme_color || '#7c3aed' %>; }
  body { font-family: 'Inter', sans-serif; background-color: #0f1117;
    <% if (settings.background_url) { %>
      background-image: linear-gradient(rgba(15,17,23,0.88), rgba(15,17,23,0.94)), url('<%= settings.background_url %>');
      background-size: cover; background-position: center; background-attachment: fixed;
    <% } %>
  }
  .accent { color: var(--accent); }
  .bg-accent { background-color: var(--accent); }
  .border-accent { border-color: var(--accent); }
  .btn-accent { background-color: var(--accent); transition: filter .15s; }
  .btn-accent:hover { filter: brightness(1.12); }
  .card { background: rgba(24,27,36,0.9); border: 1px solid rgba(255,255,255,0.06); }
</style>
